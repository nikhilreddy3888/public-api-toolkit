{
  "name": "public-api-toolkit",
  "version": "1.0.0",
  "description": "A cross-platform MCP server that turns public APIs into clean, agent-ready tools.",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "public-api-toolkit": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx --test tests/*.test.ts"
  },
  "keywords": [
    "mcp",
    "public-api-toolkit",
    "public-api",
    "public-apis",
    "codex",
    "claude-code",
    "cursor",
    "typescript",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": "Nikhil Reddy",
  "homepage": "https://github.com/nikhilreddy3888/public-api-toolkit#readme",
  "bugs": {
    "url": "https://github.com/nikhilreddy3888/public-api-toolkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nikhilreddy3888/public-api-toolkit.git"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
